# 复制本文件为 .env 并只填写你实际使用的 provider。
# 默认 provider 已切换为 deepseek（支持 prompt 缓存）。

# ---- DeepSeek（默认，推荐）-----------------------------------------------
# 走 DeepSeek 的 Anthropic 兼容接口，启用 cache_control 前缀缓存以降本提速。
MNEME_DEEPSEEK_API_BASE=https://api.deepseek.com/anthropic
MNEME_DEEPSEEK_API_KEY=
MNEME_DEEPSEEK_MODEL=deepseek-v4-pro

# ---- OpenAI 兼容接口 ------------------------------------------------------
MNEME_OPENAI_API_BASE=https://your-api.example/v1
MNEME_OPENAI_API_KEY=
MNEME_OPENAI_MODEL=gpt-5.4

# ---- Anthropic 兼容接口 ---------------------------------------------------
MNEME_ANTHROPIC_API_BASE=https://www.right.codes/claude/v1
MNEME_ANTHROPIC_API_KEY=
MNEME_ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- MCP servers（可选）---------------------------------------------------
# 一个 JSON 对象，key 是 server 名，value 含 command/args/env。
# 这些 server 暴露的工具会注册成 mcp__<server>__<tool>，默认需要审批。
# 示例：接入官方 filesystem server，把当前目录作为可读写根。
# MNEME_MCP_SERVERS={"fs":{"command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","."]}}
MNEME_MCP_SERVERS=
